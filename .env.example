# =============================================================================
# Claude Config — marketing site env vars
# =============================================================================
# Everything below is generated by `pnpm sync:release` (which calls
# scripts/sync-release.ts against the GitHub Releases API). Manual edits
# will be overwritten on the next sync.
#
# Override any value here if you need to point at a fork or a non-standard
# release URL — the sync script preserves user-managed keys in .env.local.
# =============================================================================

# Versioning
NEXT_PUBLIC_APP_VERSION=0.1.3
NEXT_PUBLIC_RELEASE_TAG=v0.1.3
NEXT_PUBLIC_RELEASES_URL=https://github.com/ayan-de/claude-config/releases
NEXT_PUBLIC_RELEASE_URL=https://github.com/ayan-de/claude-config/releases/tag/v0.1.3

# Linux downloads
NEXT_PUBLIC_DOWNLOAD_DEB=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_0.1.3_amd64.deb
NEXT_PUBLIC_DOWNLOAD_RPM=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config-0.1.3-1.x86_64.rpm
NEXT_PUBLIC_DOWNLOAD_APPIMAGE=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_0.1.3_amd64.AppImage

# macOS downloads
NEXT_PUBLIC_DOWNLOAD_DMG=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_0.1.3_universal.dmg
NEXT_PUBLIC_DOWNLOAD_APP_TAR=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_universal.app.tar.gz

# Windows downloads
NEXT_PUBLIC_DOWNLOAD_MSI=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_0.1.3_x64_en-US.msi
NEXT_PUBLIC_DOWNLOAD_EXE=https://github.com/ayan-de/claude-config/releases/download/v0.1.3/Claude.Config_0.1.3_x64-setup.exe

# Display sizes (string format like "5.27 MB")
NEXT_PUBLIC_SIZE_DEB=5.27 MB
NEXT_PUBLIC_SIZE_RPM=5.27 MB
NEXT_PUBLIC_SIZE_APPIMAGE=79 MB
NEXT_PUBLIC_SIZE_DMG=10 MB
NEXT_PUBLIC_SIZE_MSI=3.99 MB
NEXT_PUBLIC_SIZE_EXE=2.87 MB
NEXT_PUBLIC_SIZE_APP_TAR=8.9 MB

# -----------------------------------------------------------------------------
# Optional: GH token for the sync script to lift API rate limits
# Create at https://github.com/settings/tokens — public-repo read-only is fine.
# Not required for the public Releases endpoint, but useful in CI.
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=