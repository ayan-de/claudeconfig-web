# =============================================================================
# Claude Config — marketing site env vars
# =============================================================================
# Everything below is generated by `pnpm sync:release` (which calls
# scripts/sync-release.ts against the GitHub Releases API). Manual edits
# will be overwritten on the next sync.
#
# Override any value here if you need to point at a fork or a non-standard
# release URL — the sync script preserves user-managed keys in .env.local.
# =============================================================================

# Versioning
NEXT_PUBLIC_APP_VERSION=0.5.8
NEXT_PUBLIC_RELEASE_TAG=v0.5.8
NEXT_PUBLIC_RELEASES_URL=https://github.com/ayan-de/claude-config/releases
NEXT_PUBLIC_RELEASE_URL=https://github.com/ayan-de/claude-config/releases/tag/v0.5.8

# Linux downloads
NEXT_PUBLIC_DOWNLOAD_DEB=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_0.5.8_amd64.deb
NEXT_PUBLIC_DOWNLOAD_RPM=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config-0.5.8-1.x86_64.rpm
NEXT_PUBLIC_DOWNLOAD_APPIMAGE=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_0.5.8_amd64.AppImage

# macOS downloads
NEXT_PUBLIC_DOWNLOAD_DMG=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_0.5.8_universal.dmg
NEXT_PUBLIC_DOWNLOAD_APP_TAR=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_universal.app.tar.gz

# Windows downloads
NEXT_PUBLIC_DOWNLOAD_MSI=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_0.5.8_x64_en-US.msi
NEXT_PUBLIC_DOWNLOAD_EXE=https://github.com/ayan-de/claude-config/releases/download/v0.5.8/Claude.Config_0.5.8_x64-setup.exe

# Display sizes (string format like "5.27 MB")
NEXT_PUBLIC_SIZE_DEB=8.05 MB
NEXT_PUBLIC_SIZE_RPM=8.05 MB
NEXT_PUBLIC_SIZE_APPIMAGE=81.65 MB
NEXT_PUBLIC_SIZE_DMG=15.36 MB
NEXT_PUBLIC_SIZE_MSI=6.52 MB
NEXT_PUBLIC_SIZE_EXE=5.04 MB
NEXT_PUBLIC_SIZE_APP_TAR=14.47 MB

